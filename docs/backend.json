{
  "entities": {
    "UserProfile": {
      "title": "Perfil do Usuário",
      "description": "Informações da conta do usuário",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" }
      },
      "required": ["uid", "email"]
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "Armazenamento de perfis de usuários"
    }
  }
}
